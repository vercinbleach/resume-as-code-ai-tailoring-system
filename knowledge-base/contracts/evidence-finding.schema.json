{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.resume/knowledge-base/evidence-finding.schema.json",
  "title": "Resume evidence review findings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "role", "findings"],
  "properties": {
    "schema_version": {"const": 2},
    "role": {"enum": ["evidence-reviewer", "claim-risk-critic"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "criterion_id",
          "status",
          "claim_ids",
          "evidence_strength",
          "reason",
          "caveats",
          "follow_up_questions",
          "resume_safe"
        ],
        "properties": {
          "finding_id": {"type": "string", "pattern": "^finding-[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "criterion_id": {"type": "string", "minLength": 1},
          "status": {"enum": ["strong", "partial", "missing", "conflict"]},
          "claim_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^claim-"}
          },
          "evidence_strength": {"enum": ["high", "medium", "low", "none"]},
          "reason": {"type": "string", "minLength": 1},
          "caveats": {"type": "array", "items": {"type": "string"}},
          "follow_up_questions": {"type": "array", "items": {"type": "string"}},
          "resume_safe": {"type": "boolean"}
        }
      }
    }
  }
}
