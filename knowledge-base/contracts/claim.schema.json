{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.resume/knowledge-base/claim.schema.json",
  "title": "Knowledge base structured claims block",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "claims", "evidence_gaps"],
  "properties": {
    "schema_version": {"const": 1},
    "claims": {
      "type": "array",
      "items": {"$ref": "#/$defs/claim"}
    },
    "evidence_gaps": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence_gap"}
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "statement",
        "dimensions",
        "technologies",
        "evidence",
        "confidence",
        "status",
        "resume_safe",
        "sensitivity",
        "aliases",
        "caveats"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^claim-[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "statement": {"type": "string", "minLength": 10},
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "ai",
              "collaboration",
              "impact",
              "infrastructure",
              "leadership",
              "open-source",
              "operations",
              "product",
              "reliability",
              "security",
              "technical"
            ]
          }
        },
        "technologies": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_type", "locator", "checked"],
            "properties": {
              "source_type": {
                "enum": [
                  "historical-cv",
                  "inferred",
                  "linkedin",
                  "local-verification",
                  "repository-verified",
                  "user-confirmed"
                ]
              },
              "locator": {"type": "string", "minLength": 1},
              "checked": {"type": "string", "format": "date"}
            }
          }
        },
        "confidence": {"enum": ["high", "medium", "low"]},
        "status": {"enum": ["confirmed", "partial", "unverified", "conflicting"]},
        "resume_safe": {"type": "boolean"},
        "sensitivity": {"enum": ["public", "internal-anonymized", "confidential"]},
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "caveats": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "evidence_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "importance", "status", "affects_claims"],
      "properties": {
        "id": {"type": "string", "pattern": "^gap-[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "question": {"type": "string", "minLength": 10},
        "importance": {"enum": ["high", "medium", "low"]},
        "status": {"enum": ["open", "resolved", "unrecoverable"]},
        "affects_claims": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^claim-"}
        }
      }
    }
  }
}
