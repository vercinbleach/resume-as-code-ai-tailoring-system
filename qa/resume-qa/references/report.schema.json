{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clean Resume QA report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "generated_at",
    "architecture",
    "resume",
    "job_description",
    "modes",
    "pdf_checks",
    "evaluators",
    "recommended_changes",
    "limitations",
    "sources"
  ],
  "properties": {
    "session_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "architecture": {"enum": ["clean-pdf-fanout-v3", "clean-pdf-codex-tasks-v4", "clean-pdf-codex-tasks-v5", "clean-pdf-codex-tasks-v6", "clean-pdf-codex-sandboxes-v7"]},
    "resume": {"const": "inputs/resume.pdf"},
    "job_description": {"type": ["string", "null"]},
    "job_intake": {"type": ["string", "null"]},
    "modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["pdf", "technical", "leadership", "job-match", "callback"]}
    },
    "pdf_checks": {"type": "object"},
    "coordinator_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parsed_profile": {"type": ["object", "null"]},
        "ashby_text_search": {"type": ["object", "null"]},
        "application_readiness": {"type": ["object", "null"]}
      }
    },
    "evaluators": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "technical": {"$ref": "#/$defs/evaluator"},
        "leadership": {"$ref": "#/$defs/evaluator"},
        "job-match": {"$ref": "#/$defs/evaluator"},
        "callback": {"$ref": "#/$defs/evaluator"}
      }
    },
    "recommended_changes": {
      "type": "array",
      "items": {"$ref": "#/$defs/recommendation"}
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "claim", "location"],
      "properties": {
        "source": {"enum": ["resume.pdf", "job-description.md"]},
        "claim": {"type": "string", "minLength": 1},
        "location": {"type": "string", "minLength": 1}
      }
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "score", "maximum", "rationale"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "score": {"type": "number", "minimum": 0},
        "maximum": {"type": "number", "exclusiveMinimum": 0},
        "rationale": {"type": "string", "minLength": 1}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "finding", "evidence"],
      "properties": {
        "severity": {"enum": ["positive", "high", "medium", "low"]},
        "finding": {"type": "string", "minLength": 1},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resume", "job_description", "external_context_used"],
      "properties": {
        "resume": {"const": "resume.pdf"},
        "job_description": {"type": ["string", "null"]},
        "external_context_used": {"const": false}
      }
    },
    "match_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion", "status", "job_evidence", "resume_evidence", "rationale", "action"],
      "properties": {
        "criterion": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "job_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "resume_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "rationale": {"type": "string", "minLength": 1},
        "action": {"type": "string", "minLength": 1}
      }
    },
    "boolean_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["term", "aliases", "status", "resume_evidence", "notes"],
      "properties": {
        "term": {"type": "string", "minLength": 1},
        "aliases": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "status": {"enum": ["present", "missing", "uncertain"]},
        "resume_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "notes": {"type": "string", "minLength": 1}
      }
    },
    "parsing_risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "status", "evidence", "action"],
      "properties": {
        "check": {"type": "string", "minLength": 1},
        "status": {"enum": ["pass", "risk", "unknown"]},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "action": {"type": "string", "minLength": 1}
      }
    },
    "consistency_risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "status", "resume_evidence", "job_evidence", "action"],
      "properties": {
        "field": {"type": "string", "minLength": 1},
        "status": {"enum": ["consistent", "conflict", "unknown"]},
        "resume_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "job_evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
        "action": {"type": "string", "minLength": 1}
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "reason", "source", "blocks_application"],
      "properties": {
        "question": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "blocks_application": {"type": "boolean"}
      }
    },
    "job_match_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hard_gates", "must_have", "preferred", "boolean_coverage", "parsing_risks", "consistency_risks", "questions_needed"],
      "properties": {
        "hard_gates": {"type": "array", "items": {"$ref": "#/$defs/match_criterion"}},
        "must_have": {"type": "array", "items": {"$ref": "#/$defs/match_criterion"}},
        "preferred": {"type": "array", "items": {"$ref": "#/$defs/match_criterion"}},
        "boolean_coverage": {"type": "array", "items": {"$ref": "#/$defs/boolean_coverage"}},
        "parsing_risks": {"type": "array", "items": {"$ref": "#/$defs/parsing_risk"}},
        "consistency_risks": {"type": "array", "items": {"$ref": "#/$defs/consistency_risk"}},
        "questions_needed": {"type": "array", "items": {"$ref": "#/$defs/question"}}
      }
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluator", "score", "confidence", "summary", "categories", "findings", "gaps", "input_boundary"],
      "properties": {
        "schema_version": {"type": "string"},
        "evaluator": {"enum": ["technical", "leadership", "job-match", "callback"]},
        "decision": {"enum": ["strong-callback", "callback", "borderline", "no-callback"]},
        "score": {"type": "number", "minimum": 0, "maximum": 100},
        "confidence": {"enum": ["high", "medium", "low"]},
        "summary": {"type": "string", "minLength": 1},
        "categories": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/category"}},
        "job_match_matrix": {"type": "object"},
        "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
        "gaps": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "input_boundary": {"$ref": "#/$defs/boundary"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"evaluator": {"const": "callback"}},
            "required": ["evaluator"]
          },
          "then": {"required": ["decision"]}
        }
      ]
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priority", "change", "reason", "evidence"],
      "properties": {
        "priority": {"enum": ["high", "medium", "low"]},
        "change": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}
      }
    }
  }
}
